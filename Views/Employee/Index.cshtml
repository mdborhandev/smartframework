@{
    ViewData["Title"] = "Employee List";
}

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Employee List</h4>
            <div class="d-flex gap-2">
                <input type="text" id="searchInput" class="form-control" placeholder="Search..." style="width: 250px;">
                <button class="btn btn-primary" onclick="openModal(0)">+ Add</button>
            </div>
        </div>
        <div class="card-body">
            <div id="employeeTable"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="employeeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="employeeForm">
                    <input type="hidden" id="empId" value="0" />
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input id="empName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input id="empEmail" type="email" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Phone</label>
                        <input id="empPhone" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <input id="empDepartment" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Salary</label>
                        <input id="empSalary" type="number" step="0.01" class="form-control" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveEmployee()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let table;

        function loadData() {
            var search = $("#searchInput").val() || "";
            $.get("/Employee/GetData", { page: 1, size: 0, search: search }, function (res) {
                table.setData(res.data);
                table.setPage(1);
            });
        }

        $(document).ready(function () {
            table = new Tabulator("#employeeTable", {
                layout: "fitColumns",
                pagination: "local",
                paginationSize: 5,
                paginationSizeSelector: [5, 10, 20],
                columns: [
                    { title: "Name", field: "name", sorter: "string", width: 150 },
                    { title: "Email", field: "email", sorter: "string" },
                    { title: "Phone", field: "phone", sorter: "string", width: 130 },
                    { title: "Department", field: "department", sorter: "string", width: 100 },
                    { title: "Salary", field: "salary", sorter: "number", formatter: "money", formatterParams: { precision: 2 }, width: 120 },
                    {
                        title: "Action", field: "id", width: 150, formatter: function (cell) {
                            const id = cell.getValue();
                            return `<button class="btn btn-sm btn-warning me-1" onclick="openModal(${id})">Edit</button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteEmployee(${id})">Delete</button>`;
                        }
                    }
                ]
            });

            loadData();

            let searchTimer;
            $("#searchInput").on("keyup", function () {
                clearTimeout(searchTimer);
                searchTimer = setTimeout(function () {
                    loadData();
                }, 300);
            });
        });

        function openModal(id) {
            $("#empId").val(id);
            if (id === 0) {
                $("#modalTitle").text("Add Employee");
                $("#employeeForm")[0].reset();
                $("#employeeModal").modal("show");
                return;
            }

            $.get("/Employee/GetById/" + id, function (data) {
                $("#modalTitle").text("Edit Employee");
                $("#empId").val(data.id);
                $("#empName").val(data.name);
                $("#empEmail").val(data.email);
                $("#empPhone").val(data.phone || "");
                $("#empDepartment").val(data.department || "");
                $("#empSalary").val(data.salary || 0);
                $("#employeeModal").modal("show");
            });
        }

        function saveEmployee() {
            const data = {
                Id: parseInt($("#empId").val()),
                Name: $("#empName").val(),
                Email: $("#empEmail").val(),
                Phone: $("#empPhone").val(),
                Department: $("#empDepartment").val(),
                Salary: parseFloat($("#empSalary").val()) || 0
            };

            $.ajax({
                url: "/Employee/Save",
                method: "POST",
                contentType: "application/json",
                data: JSON.stringify(data),
                success: function () {
                    $("#employeeModal").modal("hide");
                    loadData();
                    var isEdit = parseInt($("#empId").val()) > 0;
                    toastr.success(isEdit ? "Employee updated successfully!" : "Employee created successfully!");
                },
                error: function () {
                    toastr.error("Error saving employee");
                }
            });
        }

        function deleteEmployee(id) {
            if (!confirm("Delete this employee?")) return;
            $.post("/Employee/Delete/" + id, function () {
                loadData();
                toastr.success("Employee deleted successfully!");
            });
        }
    </script>
}
